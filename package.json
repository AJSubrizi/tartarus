{
  "name": "tartarus",
  "version": "0.7.2",
  "author": {
    "name": "AJSubrizi",
    "email": "ajsubrizi@users.noreply.github.com"
  },
  "private": false,
  "type": "module",
  "description": "The harness for the harnesses — MCP so Claude/Codex/Cursor orchestrate other agents",
  "bin": {
    "tartarus": "./dist/cli.js"
  },
  "main": "desktop/main.cjs",
  "files": [
    "dist",
    "desktop",
    "install.sh",
    "README.md",
    "PRODUCT.md",
    "LICENSE",
    "CHANGELOG.md",
    "examples"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts serve",
    "dev:mcp": "tsx src/cli.ts mcp",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "prepare": "node scripts/ensure-build.mjs",
    "start": "node dist/cli.js app",
    "app": "node dist/cli.js app",
    "desktop": "pnpm build && electron .",
    "desktop:pack": "pnpm build && electron-builder --mac dir --publish never",
    "desktop:pack:all": "pnpm build && electron-builder -mwl --publish never",
    "desktop:open": "pnpm desktop:pack && open release/mac-arm64/Tartarus.app || open release/mac/Tartarus.app",
    "mcp": "node dist/cli.js mcp",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "doctor": "tsx src/cli.ts doctor",
    "setup": "tsx src/cli.ts setup",
    "adapters": "tsx src/cli.ts adapters",
    "preview": "tsx src/cli.ts preview",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "dev.tartarus.app",
    "productName": "Tartarus",
    "copyright": "Copyright © AJSubrizi",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dir"
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "maintainer": "AJSubrizi <ajsubrizi@users.noreply.github.com>",
      "desktopName": "Tartarus"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "dmg": {
      "title": "Tartarus"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "codex",
    "cursor",
    "agents",
    "harness",
    "worktree"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AJSubrizi/tartarus.git"
  },
  "bugs": {
    "url": "https://github.com/AJSubrizi/tartarus/issues"
  },
  "homepage": "https://github.com/AJSubrizi/tartarus#readme"
}
