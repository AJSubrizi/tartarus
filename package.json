{
  "name": "tartarus",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "description": "The harness for the harnesses — MCP primitives so Claude/Codex/Cursor orchestrate other agents",
  "bin": {
    "tartarus": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "install.sh",
    "README.md",
    "PRODUCT.md",
    "LICENSE",
    "CHANGELOG.md",
    "examples"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts serve",
    "dev:mcp": "tsx src/cli.ts mcp",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "start": "node dist/cli.js serve",
    "mcp": "node dist/cli.js mcp",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "doctor": "tsx src/cli.ts doctor",
    "adapters": "tsx src/cli.ts adapters",
    "preview": "tsx src/cli.ts preview",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "codex",
    "cursor",
    "agents",
    "harness",
    "worktree",
    "orchestration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AJSubrizi/tartarus.git"
  },
  "bugs": {
    "url": "https://github.com/AJSubrizi/tartarus/issues"
  },
  "homepage": "https://github.com/AJSubrizi/tartarus#readme"
}
